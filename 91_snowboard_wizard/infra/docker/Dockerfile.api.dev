FROM node:22-alpine
RUN corepack enable && corepack prepare pnpm@11.8.0 --activate
WORKDIR /app

# Install all dependencies (devDeps needed for NestJS CLI + TypeScript compiler)
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY apps/api/package.json apps/api/
COPY packages/types/package.json packages/types/
COPY packages/wizard-schema/package.json packages/wizard-schema/
COPY packages/ui/package.json packages/ui/
RUN pnpm install --frozen-lockfile

# Copy workspace package sources and build them
# (api/src is mounted at runtime — not copied here)
COPY tsconfig.base.json ./
COPY packages/types/ packages/types/
COPY packages/wizard-schema/ packages/wizard-schema/
RUN pnpm --filter @snowboard/types build
RUN pnpm --filter @snowboard/wizard-schema build

# Copy api config files (not src — that's a volume mount)
COPY apps/api/tsconfig.json apps/api/
COPY apps/api/tsconfig.build.json apps/api/

EXPOSE 3001
CMD ["pnpm", "--filter", "@snowboard/api", "dev"]
